{
  "name": "quantumshield",
  "displayName": "QuantumShield",
  "description": "Quantum-safe cryptography scanner — find and fix quantum-vulnerable crypto",
  "version": "0.1.0",
  "publisher": "quantumshield",
  "engines": {"vscode": "^1.85.0"},
  "categories": ["Linters", "Other"],
  "activationEvents": ["onLanguage:go", "onLanguage:python", "onLanguage:javascript", "onLanguage:typescript", "onLanguage:java"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {"command": "quantumshield.scan", "title": "QuantumShield: Scan Project"},
      {"command": "quantumshield.scanFile", "title": "QuantumShield: Scan Current File"}
    ],
    "configuration": {
      "title": "QuantumShield",
      "properties": {
        "quantumshield.path": {"type": "string", "default": "qs", "description": "Path to qs binary"},
        "quantumshield.autoScan": {"type": "boolean", "default": true, "description": "Scan on file save"},
        "quantumshield.severity": {"type": "string", "default": "all", "enum": ["all", "critical", "high", "medium"], "description": "Minimum severity to display"}
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
